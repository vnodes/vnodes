# #!/bin/bash


pnpm nx run-many  -t prisma:generate --tuiAutoExit=true 
pnpm nx run-many  -t lint --tuiAutoExit=true 

pnpm nx run-many  -t build --projects="tag:lib:types"  --tuiAutoExit=true
pnpm nx run-many  -t build --projects="tag:lib:shared"  --tuiAutoExit=true
pnpm nx run-many  -t build --projects="tag:lib:module"  --tuiAutoExit=true
pnpm nx run-many  -t build --projects="tag:lib:core"  --tuiAutoExit=true
pnpm nx run-many  -t build --projects="tag:app:*"  --tuiAutoExit=true

pnpm nx run-many  -t test --projects="tag:lib:types"  --tuiAutoExit=true
pnpm nx run-many  -t test --projects="tag:lib:shared"  --tuiAutoExit=true
pnpm nx run-many  -t test --projects="tag:lib:module"  --tuiAutoExit=true
