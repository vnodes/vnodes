{
  "name": "@vnodes/autowire",
  "version": "0.1.0",
  "description": "@vnodes/autowire",
  "keywords": [
    "autowire"
  ],
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline+vnodes-autowire@gmail.com",
    "url": "https://vnodes.github.io/vnodes"
  },
  "homepage": "https://vnodes.github.io/vnodes/libs/autowire",
  "icon": "https://vnodes.github.io/vnodes/libs/autowire/assets/favicon.png",
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "bin": {
    "version": "./bin/version.mjs"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@vnodes/source": "./src/lib/controller/index.ts",
      "types": "./dist/lib/controller/index.d.ts",
      "import": "./dist/lib/controller/index.js",
      "default": "./dist/lib/controller/index.js"
    },
    "./controller": {
      "types": "./dist/lib/controller/index.d.ts",
      "import": "./dist/lib/controller/index.js",
      "default": "./dist/lib/controller/index.js"
    },
    "./resolver": {
      "types": "./dist/lib/resolver/index.d.ts",
      "import": "./dist/lib/resolver/index.js",
      "default": "./dist/lib/resolver/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "!**/*.tsbuildinfo",
    "assets"
  ],
  "nx": {
    "sourceRoot": "libs/autowire/src",
    "tags": [
      "lib"
    ],
    "targets": {
      "build": {},
      "doc": {},
      "lint": {}
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "devDependencies": {
    "@vnodes/errors": "workspace:*",
    "@vnodes/graphql": "workspace:*",
    "@vnodes/metadata": "workspace:*",
    "@vnodes/names": "workspace:*",
    "@vnodes/nestjs": "workspace:*",
    "@vnodes/types": "workspace:*",
    "@vnodes/utils": "workspace:*"
  },
  "peerDependencies": {
    "@vnodes/errors": "workspace:*",
    "@vnodes/graphql": "workspace:*",
    "@vnodes/metadata": "workspace:*",
    "@vnodes/names": "workspace:*",
    "@vnodes/nestjs": "workspace:*",
    "@vnodes/types": "workspace:*",
    "@vnodes/utils": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
