    "@vnodes/metadata": "workspace:*",
    "@vnodes/nestjs": "workspace:*",
    "@vnodes/types": "workspace:*"
  },
  "peerDependencies": {
    "@vnodes/env": "workspace:*",
    "@vnodes/graphql": "workspace:*",
    "@vnodes/metadata": "workspace:*",
    "@vnodes/nestjs": "workspace:*",
    "@vnodes/types": "workspace:*"
