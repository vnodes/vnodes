   "import": "./dist/nestjs-jwt.js",
   "default": "./dist/nestjs-jwt.js"
  },
  "./nestjs-platform-express": {
   "types": "./dist/nestjs-platform-express.d.ts",
   "import": "./dist/nestjs-platform-express.js",
   "default": "./dist/nestjs-platform-express.js"
  },
  "./nestjs-platform-fastify": {
   "types": "./dist/nestjs-platform-fastify.d.ts",
   "import": "./dist/nestjs-platform-fastify.js",
   "default": "./dist/nestjs-platform-fastify.js"
  },
  "./nestjs-schedule": {
   "types": "./dist/nestjs-schedule.d.ts",
   "import": "./dist/nestjs-schedule.js",
   "default": "./dist/nestjs-schedule.js"
  },
  "./nestjs-swagger": {
   "types": "./dist/nestjs-swagger.d.ts",
