{
 "name": "@vnodes/nestjs",
 "version": "0.0.1",
 "description": "@vnodes/nestjs",
 "keywords": [
  "nestjs"
 ],
 "author": {
  "name": "Robert Brightline",
  "email": "robert.brightline+vnodes-nestjs@gmail.com",
  "url": "https://vnodes.github.io/vnodes"
 },
 "homepage": "https://vnodes.github.io/vnodes/libs/nestjs",
