   "default": "./dist/nestjs-swagger.js"
  },
  "./nestjs-throttler": {
   "types": "./dist/nestjs-throttler.d.ts",
   "import": "./dist/nestjs-throttler.js",
   "default": "./dist/nestjs-throttler.js"
  },
  "./class-transformer": {
   "types": "./dist/class-transformer.d.ts",
   "import": "./dist/class-transformer.js",
   "default": "./dist/class-transformer.js"
  },
  "./class-validator": {
   "types": "./dist/class-validator.d.ts",
   "import": "./dist/class-validator.js",
   "default": "./dist/class-validator.js"
  },
  "./express": {
   "types": "./dist/express.d.ts",
   "import": "./dist/express.js",
   "default": "./dist/express.js"
  },
  "./fastify": {
   "types": "./dist/fastify.d.ts",
   "import": "./dist/fastify.js",
   "default": "./dist/fastify.js"
  },
  "./helmet": {
