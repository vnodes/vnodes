  "https://cash.app/$puqlib"
 ],
 "bin": {
  "version": "./bin/version.mjs"
 },
 "type": "module",
 "main": "./dist/index.js",
 "module": "./dist/index.js",
 "types": "./dist/index.d.ts",
 "exports": {
  "./package.json": "./package.json",
  ".": {
   "@vnodes/source": "./src/index.ts",
