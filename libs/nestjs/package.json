   "import": "./dist/index.js",
   "default": "./dist/index.js"
  },
  "./fastify-compress": {
   "types": "./dist/fastify-compress.d.ts",
   "import": "./dist/fastify-compress.js",
   "default": "./dist/fastify-compress.js"
  },
  "./fastify-helmet": {
   "types": "./dist/fastify-helmet.d.ts",
   "import": "./dist/fastify-helmet.js",
   "default": "./dist/fastify-helmet.js"
  },
  "./nestjs-common": {
   "types": "./dist/nestjs-common.d.ts",
   "import": "./dist/nestjs-common.js",
   "default": "./dist/nestjs-common.js"
  },
  "./nestjs-core": {
   "types": "./dist/nestjs-core.d.ts",
   "import": "./dist/nestjs-core.js",
   "default": "./dist/nestjs-core.js"
  },
  "./nestjs-event-emitter": {
   "types": "./dist/nestjs-event-emitter.d.ts",
