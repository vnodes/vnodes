{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "resolvePackageJsonExports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@vnodes/test-api/client": [
        "./src/generated/prisma/client.js"
      ],
      "@vnodes/test-api/browser": [
        "./src/generated/prisma/browser.js"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "../../packages/types/tsconfig.lib.json"
    },
    {
      "path": "../../packages/prisma/tsconfig.lib.json"
    },
    {
      "path": "../../packages/nest/tsconfig.lib.json"
    }
  ]
}