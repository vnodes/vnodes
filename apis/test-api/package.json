{
  "name": "@vnodes/test-api",
  "version": "0.1.2",
  "author": {
    "email": "robert.brightline+vnodes-test-api@gmail.com",
    "name": "Robert Brightline",
    "url": "https://vnodes.github.io"
  },
  "keywords": [
    "library",
    "types"
  ],
  "bugs": {
    "email": "robert.brightline+vnodes-test-api@gmail.com",
    "url": "https://github.com/vnodes/vnodes/issues"
  },
  "homepage": "https://vnodes.github.io/apis/test-api",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "files": [
    "dist",
    "assets"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/src/generated/prisma/client.d.ts",
      "import": "./dist/src/generated/prisma/client.js",
      "default": "./dist/src/generated/prisma/client.js"
    },
    "./browser": {
      "types": "./dist/src/generated/prisma/browser.d.ts",
      "import": "./dist/src/generated/prisma/browser.js",
      "default": "./dist/src/generated/prisma/browser.js"
    }
  },
  "nx": {
    "sourceRoot": "apis/test-api/src",
    "tags": [
      "app:api"
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "{projectRoot}/dist",
          "main": "{projectRoot}/src/main.ts",
          "tsConfig": "{projectRoot}/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": false
        }
      },
      "preserve": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "{projectRoot}/out",
          "main": "{projectRoot}/src/main.ts",
          "tsConfig": "{projectRoot}/tsconfig.app.json",
          "generatePackageJson": false
        }
      },
      "serve": {
        "executor": "@nx/js:node",
        "options": {
          "buildTarget": "preserve",
          "watch": true
        },
        "dependsOn": [
          "preserve"
        ]
      },
      "prisma:migrate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm prisma migrate dev --name updated",
          "cwd": "{projectRoot}"
        }
      },
      "prisma:reset": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm prisma migrate reset -f",
          "cwd": "{projectRoot}"
        }
      },
      "prisma:generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm prisma generate",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "peerDependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vnodes/nest": "workspace:*",
    "@vnodes/prisma": "workspace:*",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.21.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vnodes/nest": "workspace:*",
    "@vnodes/prisma": "workspace:*",
    "@vnodes/types": "workspace:*",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.21.0",
    "rxjs": "^7.8.2"
  }
}