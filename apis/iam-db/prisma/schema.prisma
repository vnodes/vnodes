generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator dtos {
  provider = "prisma-nest-dto"
  output   = "../src/generated/nest"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid(7)) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  updatedBy User? @relation("updated_by_audit", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  /// @internal() @param(userId)
  updatedById Int? @map("updated_by_id")

  /// @minLength(3) /// @notIn([root, admin, superuser, super, sudo]) @casing(sentence)
  username String @unique

  /// @format(password) @hash()
  password String

  /// @internal()
  isTwoFactorAuthEnabled Boolean @default(false) @map("is_two_factor_auth_enabled")

  /// @internal()
  lastLoginAt DateTime? @map("last_login_at")

  /// @include()
  userRoles UserRole[]

  updatedUsers        User[]        @relation("updated_by_audit")
  updatedRoles        Role[]
  updatedPermissions  Permission[]
  updatedHttpHooks    HttpHook[]
  updatedAccessTokens AccessToken[]
  updatedEvents       Event[]
  updatedSamples      Sample[]
  updatedCategories   Category[]

  @@map("users")
}

model Role {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")
  /// @minLength(3)
  name        String    @unique

  /// @minLength(3)
  description String?

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")

  /// @minLength(3)
  name String @unique

  rolePermissions        RolePermission[]
  accessTokenPermissions AccessTokenPermission[]

  @@map("permissions")
}

model RolePermission {
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleId Int  @map("role_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permissionId Int        @map("permission_id")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId Int  @map("user_id")

  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleId Int  @map("role_id")

  @@id([userId, roleId])
  @@map("user_roles")
}

model AccessToken {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")

  name  String @unique
  token String /// @hash()

  isExpired Boolean @default(false) @map("is_expired")

  accessTokenPermissions AccessTokenPermission[]

  @@map("access_tokens")
}

model AccessTokenPermission {
  accessToken   AccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  accessTokenId Int         @map("access_token_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permissionId Int        @map("permission_id")

  @@id([accessTokenId, permissionId])
  @@map("access_token_permissions")
}

model Event {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")

  name        String  @unique
  description String?

  httpHookEvents HttpHookEvent[]

  @@map("events")
}

model HttpHook {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")

  name          String    @unique
  description   String?
  url           String /// @format(url)
  retryCount    Int       @default(3) @map("retry_count")
  failureCount  Int       @default(0) @map("failure_count")
  lastFailureAt DateTime? @map("last_failure_at")
  lastSuccessAt DateTime? @map("last_success_at")

  httpHookEvents HttpHookEvent[]

  @@map("http_hooks")
}

model HttpHookEvent {
  httpHook   HttpHook @relation(fields: [httpHookId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  httpHookId Int      @map("http_hook_id")

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  eventId Int   @map("event_id")

  @@id([httpHookId, eventId])
  @@map("http_hook_events")
}

model Category {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  updatedBy User? @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  /// @internal() @param(userId)
  updatedByUserId Int? @map("updated_by_user_id")

  name        String  @unique
  description String?

  parentCategory   Category? @relation("categories", fields: [parentCategoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parentCategoryId Int?      @map("parent_category_id")

  categories Category[] @relation("categories")

  @@map("categories")
}

model Sample {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// @internal() @param(userId)
  updatedById Int?      @map("updated_by_id")

  name        String  @unique
  description String?

  @@map("samples")
}
