generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator dtos {
  provider = "prisma-nest-dto"
  output   = "../src/generated/nest"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid(7)) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255) @isNotIn([admin, root, super, sudo]) @casing(sentence)
  username String @unique

  /// @format(password) @hash()
  password String

  /// @internal()
  isTwoFactorAuthEnabled Boolean @default(false) @map("is_two_factor_auth_enabled")

  /// @internal()
  lastLoginAt DateTime? @map("last_login_at")

  /// @include()
  userRoles UserRole[]

  @@map("users")
}

model Role {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255)
  name String @unique

  /// @maxLength(400)
  description String?

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255)
  name String @unique

  rolePermissions        RolePermission[]
  accessTokenPermissions AccessTokenPermission[]

  @@map("permissions")
}

model RolePermission {
  id Int @id @default(autoincrement())

  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  roleId Int  @map("role_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  permissionId Int        @map("permission_id")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  userId Int  @map("user_id")

  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  roleId Int  @map("role_id")

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AccessToken {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255)
  name String @unique

  /// @hash()
  token     String
  isExpired Boolean @default(false) @map("is_expired")

  accessTokenPermissions AccessTokenPermission[]

  @@map("access_tokens")
}

model AccessTokenPermission {
  id Int @id @default(autoincrement())

  accessToken   AccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  accessTokenId Int         @map("access_token_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  permissionId Int        @map("permission_id")

  @@unique([accessTokenId, permissionId])
  @@map("access_token_permissions")
}

model Event {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  name        String  @unique
  description String?

  httpHookEvents HttpHookEvent[]

  @@map("events")
}

model HttpHook {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255)
  name String @unique

  /// @maxLength(1000)
  description String?

  /// @format(url)
  url String

  /// @internal()
  retryCount Int @default(3) @map("retry_count")

  /// @internal()
  failureCount Int @default(0) @map("failure_count")

  /// @internal()
  lastFailureAt DateTime? @map("last_failure_at")

  /// @internal()
  lastSuccessAt DateTime? @map("last_success_at")

  /// @include()
  httpHookEvents HttpHookEvent[]

  @@map("http_hooks")
}

model HttpHookEvent {
  id Int @id @default(autoincrement())

  httpHook   HttpHook @relation(fields: [httpHookId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  httpHookId Int      @map("http_hook_id")

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// @minimum(1) @format(int32)
  eventId Int   @map("event_id")

  @@unique([httpHookId, eventId])
  @@map("http_hook_events")
}

model Category {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  /// @minLength(3) @maxLength(255)
  name String @unique

  /// @maxLength(400)
  description String?

  parentCategory   Category? @relation("categories", fields: [parentCategoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parentCategoryId Int?      @map("parent_category_id")

  categories Category[] @relation("categories")

  @@map("categories")
}

model Sample {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  name        String  @unique
  description String?

  @@map("samples")
}
