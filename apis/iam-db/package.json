{
  "name": "@vnodes/iam-db",
  "description": "Identity and access management database",
  "version": "0.1.8",
  "author": {
    "email": "robert.brightline+vnodes-iam-db@gmail.com",
    "name": "Robert Brightline",
    "url": "https://vnodes.github.io"
  },
  "keywords": [
    "database",
    "prisma"
  ],
  "bugs": {
    "email": "robert.brightline+vnodes-iam-db@gmail.com",
    "url": "https://github.com/vnodes/vnodes/issues"
  },
  "homepage": "https://vnodes.github.io/apis/iam-db",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "bin": {
    "iam-db": "./bin/iam-db.mjs"
  },
  "files": [
    "bin",
    "dist",
    "assets",
    "prisma",
    "prisma.config.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/generated/prisma/client.d.ts",
      "import": "./dist/generated/prisma/client.js",
      "default": "./dist/generated/prisma/client.js"
    },
    "./browser": {
      "types": "./dist/generated/prisma/browser.d.ts",
      "import": "./dist/generated/prisma/browser.js",
      "default": "./dist/generated/prisma/browser.js"
    }, 
    "./nest":{ 
      "types": "./dist/generated/nest/index.d.ts",
      "import": "./dist/generated/nest/index.js",
      "default": "./dist/generated/nest/index.js"
    }
  },
  "nx": {
    "sourceRoot": "apis/iam-db/src",
    "tags": [
      "app:db"
    ],
    "targets": {
      "build": {},
      "prisma:migrate": {},
      "prisma:reset": {},
      "prisma:generate": {}
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@vnodes/names": "workspace:*",
    "@vnodes/prisma": "workspace:*",
    "@vnodes/prop": "workspace:*",
    "@vnodes/types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^7.8.0",
    "@vnodes/names": "workspace:*",
    "@vnodes/nest": "workspace:*",
    "@vnodes/prisma": "workspace:*",
    "@vnodes/prop": "workspace:*",
    "@vnodes/types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2"
  }
}
