{
  "name": "@vnodes/test-db",
  "description": "Test database",
  "version": "0.1.7",
  "author": {
    "email": "robert.brightline+vnodes-test-db@gmail.com",
    "name": "Robert Brightline",
    "url": "https://vnodes.github.io"
  },
  "keywords": [
    "library",
    "types"
  ],
  "bugs": {
    "email": "robert.brightline+vnodes-test-db@gmail.com",
    "url": "https://github.com/vnodes/vnodes/issues"
  },
  "homepage": "https://vnodes.github.io/apis/test-db",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "files": [
    "bin",
    "dist",
    "assets",
    "prisma",
    "prisma.config.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/generated/prisma/client.d.ts",
      "import": "./dist/generated/prisma/client.js",
      "default": "./dist/generated/prisma/client.js"
    },
    "./browser": {
      "types": "./dist/generated/prisma/browser.d.ts",
      "import": "./dist/generated/prisma/browser.js",
      "default": "./dist/generated/prisma/browser.js"
    }
  },
  "nx": {
    "sourceRoot": "apis/test-db/src",
    "tags": [
      "app:db"
    ],
    "targets": {
      "build": {},
      "prisma:migrate": {},
      "prisma:reset": {},
      "prisma:generate": {},
      "doc": {}
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "peerDependencies": {
    "@prisma/client": "^7.8.0",
    "@vnodes/env": "workspace:*"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@vnodes/env": "workspace:*"
  }
}
