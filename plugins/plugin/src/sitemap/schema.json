{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "Sitemap",
    "title": "Sitemap generator",
    "type": "object",
    "properties": {
        "baseUrl": {
            "type": "string",
            "description": "",
            "$default": {
                "$source": "argv",
                "index": 0
            }
        },
        "pages": {
            "type": "string",
            "description": "List of pages",
            "$default": {
                "$source": "argv",
                "index": 1
            }
        }
    }
}
