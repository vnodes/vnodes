{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "Component",
    "title": "",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "component name",
            "$default": {
                "$source": "argv",
                "index": 0
            },
            "x-prompt": "What name would you like to use?"
        },
        "project": {
            "type": "string",
            "description": "Project name",
            "$default": {
                "$source": "argv",
                "index": 1
            },
            "x-prompt": "What project would you like to use?"
        },
        "type": {
            "type": "string",
            "description": "Component type",
            "enum": ["component", "pipe"],
            "$default": {
                "$source": "argv",
                "index": 2
            },
            "x-prompt": "What component type would you like to use?"
        }
    },
    "required": ["name", "project"]
}
