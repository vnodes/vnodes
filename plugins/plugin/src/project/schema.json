{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "Project",
    "title": "",
    "type": "object",
    "properties": {
        "projectType": {
            "type": "string",
            "enum": ["lib", "lib-conf", "api", "cli", "prisma", "gql", "grpc"],
            "$default": {
                "$source": "argv",
                "index": 0
            },
            "x-prompt": "Which project-type would you like to use?"
        },
        "directory": {
            "type": "string",
            "$default": {
                "$source": "argv",
                "index": 1
            },
            "x-prompt": "Which diretory would you like to use?"
        },
        "homepage": {
            "type": "string"
        },
        "email": {
            "type": "string"
        },
        "author": {
            "type": "string"
        },
        "funding": {
            "type": "string"
        },
        "reponame": {
            "type": "string"
        },
        "orgname": {
            "type": "string"
        },
        "version": {
            "type": "string"
        }
    },
    "required": ["projectType", "directory"]
}
