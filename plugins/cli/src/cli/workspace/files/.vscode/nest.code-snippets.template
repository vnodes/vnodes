{
    "metadata decorator": {
        "prefix": "metadata decorator",
        "body": [
            "import { SetMetadata } from '@nestjs/common';",
            "import { MetadataToken } from '../constants/metadata-token.js';",
            "",
            "export function $1(): MethodDecorator {",
            "  return (...args) => {",
            "    SetMetadata(MetadataToken.$2, $3)(...args);",
            "  };",
            "}",
        ],
        "scope": "typescript"
    }
}