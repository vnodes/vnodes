{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "Generator",
  "title": "Generate Generator",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Generator name",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    }
  },
  "required": ["name"]
}
