{
  "jsc": {
    "target": "es2022",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "keepClassNames": true,
    "externalHelpers": true,
    "loose": false,
    "preserveAllComments": true
  },
  "module": {
    "type": "nodenext",
    "strict": true,
    "strictMode": true
  },
  "sourceMaps": true, 
  "exclude": [
    ".*\\.spec\\.ts$"
  ]
}