{
    "name": "@vnodes/ctc",
    "description": "@vnodes/ctc",
    "homepage": "https://vnodes.github.io/vnodes/apps/ctc",
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "author": {
        "email": "robert.brightline+vnodes-ctc@gmail.com",
        "name": "Robert Brightline",
        "url": "https://vnodes.github.io/vnodes/apps/ctc"
    },
    "keywords": [],
    "icon": "https://vnodes.github.io/vnodes/apps/ctc/assets/favicon.png",
    "funding": [
        {
            "type": "cashapp",
            "url": "https://cash.app/$puqlib"
        }
    ],
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "@vnodes/source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "assets",
        "dist",
        "!**/*.tsbuildinfo"
    ],
    "nx": {
        "sourceRoot": "apps/ctc/src",
        "targets": {
            "build": {
                "executor": "@nx/js:swc",
                "outputs": [
                    "{options.outputPath}"
                ],
                "options": {
                    "outputPath": "apps/ctc/dist",
                    "main": "apps/ctc/src/boot.ts",
                    "tsConfig": "apps/ctc/tsconfig.lib.json",
                    "skipTypeCheck": false,
                    "stripLeadingPaths": true
                }
            },
            "lint": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "npx @biomejs/biome check --write --unsafe {projectRoot}"
                }
            },
            "doc": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "npx typedoc --tsconfig apps/ctc/tsconfig.lib.json --entryPoints apps/ctc/src/index.ts --out public/apps/ctc",
                    "cwd": "{workspaceRoot}"
                }
            },
            "serve": {
                "executor": "@nx/js:node",
                "options": {
                    "buildTarget": "@vnodes/ctc:build",
                    "watch": true
                }
            }
        }
    },
    "dependencies": {
        "@swc/helpers": "~0.5.11"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.13",
        "@prisma/client": "7.3.0",
        "@vnodes/prisma-plugins": "workspace:*",
        "dotenv": "17.3.1",
        "prisma": "7.3.0"
    },
    "peerDependencies": {
        "@prisma/client": "7.3.0",
        "@vnodes/nestjs": "workspace:*"
    }
}