{
    "extends": ["../../tsconfig.base.json"],
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "src",
        "outDir": "dist",
        "tsBuildInfoFile": "dist/.tsbuildinfo"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.e2e-spec.ts", "src/**/*.e2e-test.ts"],
    "references": [
        {
            "path": "../../libs/core"
        },
        {
            "path": "../../plugins/prisma-plugins"
        }
    ]
}
