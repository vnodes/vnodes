{
    "name": "@vnodes/sample-gql",
    "version": "0.0.20",
    "description": "@vnodes/sample-gql",
    "keywords": [
        "sample-gql"
    ],
    "author": {
        "name": "Robert Brightline",
        "email": "robert.brightline+vnodes-sample-gql@gmail.com",
