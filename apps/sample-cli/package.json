{
    "name": "@vnodes/sample-cli",
    "version": "0.0.20",
    "description": "@vnodes/sample-cli",
    "keywords": [
        "sample-cli"
    ],
    "author": {
        "name": "Robert Brightline",
        "email": "robert.brightline+vnodes-sample-cli@gmail.com",
        "url": "https://vnodes.github.io/vnodes"
    },
    "homepage": "https://vnodes.github.io/vnodes/apps/sample-cli",
    "icon": "https://vnodes.github.io/vnodes/apps/sample-cli/assets/favicon.png",
    "funding": [
        "https://cash.app/$puqlib"
    ],
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "bin": {
        "sample-cli": "./bin/sample-cli.mjs"
    },
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "@vnodes/source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "bin",
        "!**/*.tsbuildinfo"
    ],
    "nx": {
        "sourceRoot": "apps/sample-cli/src",
        "tags": [
            "app"
        ],
        "targets": {
            "build": {
                "options": {
                    "main": "{projectRoot}/src/main.ts"
                }
            },
            "serve": {},
            "doc": {},
            "lint": {}
        }
    },
    "dependencies": {
        "@swc/helpers": "~0.5.18"
    },
    "devDependencies": {
        "commander": "^14.0.3"
    },
    "peerDependencies": {
        "commander": "^14.0.3"
    }
}