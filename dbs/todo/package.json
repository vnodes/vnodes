{
    "name": "@vnodes/todo",
    "description": "- [ ] add description",
    "homepage": "https://vnodes.github.io/vnodes/dbs/todo",
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "author": {
        "email": "robert.brightline+vnodes-todo@gmail.com",
        "name": "Robert Brightline",
        "url": "https://vnodes.github.io/vnodes/dbs/todo"
    },
    "keywords": [],
    "icon": "https://vnodes.github.io/vnodes/dbs/todo/assets/favicon.png",
    "funding": [
        {
            "type": "cashapp",
            "url": "https://cash.app/$puqlib"
        }
    ],
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "@vnodes/source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./browser": {
            "types": "./dist/lib/prisma/browser.d.ts",
            "import": "./dist/plib/risma/browser.js",
            "default": "./dist/lib/prisma/browser.js"
        }
    },
    "files": [
        "assets",
        "dist",
        "!**/*.tsbuildinfo"
    ],
    "nx": {
        "sourceRoot": "dbs/todo/src",
        "targets": {
            "build": {
                "executor": "@nx/js:swc",
                "outputs": [
                    "{options.outputPath}"
                ],
                "options": {
                    "outputPath": "dbs/todo/dist",
                    "main": "dbs/todo/src/index.ts",
                    "tsConfig": "dbs/todo/tsconfig.lib.json",
                    "skipTypeCheck": false,
                    "stripLeadingPaths": true
                }
            },
            "lint": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "npx @biomejs/biome check --write --unsafe {projectRoot}"
                }
            },
            "test": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "npx tsx --test src/**/*.{spec,test}.ts",
                    "cwd": "{projectRoot}"
                }
            },
            "doc": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "npx typedoc --tsconfig dbs/todo/tsconfig.lib.json --entryPoints dbs/todo/src/index.ts --out public/dbs/todo",
                    "cwd": "{workspaceRoot}"
                }
            },
            "prisma-reset": {
                "executor": "nx:run-commands",
                "options": {
                    "commands": [
                        "npx prisma migrate reset --force",
                        "npx prisma migrate dev --name reset",
                        "npx prisma generate"
                    ],
                    "cwd": "{projectRoot}"
                }
            }
        }
    },
    "dependencies": {
        "@prisma/client": "^7.3.0",
        "@swc/helpers": "~0.5.11"
    },
    "devDependencies": {
        "prisma": "^7.3.0"
    }
}
