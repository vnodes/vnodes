generator client {
  provider               = "prisma-client"
  output                 = "../src/lib/prisma"
  generatedFileExtension = "ts"
  moduleFormat           = "cjs"
  importFileExtension    = "js"
  runtime                = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  OPEN
  CLOSED
  IN_PROGRESS
}

model Todo {
  id Int @id @default(autoincrement())

  title       String  @unique
  description String? @unique

  status Status?
}
