{
  "name": "@vnodes/nest",
  "version": "1.0.0",
  "author": {
    "email": "robert.brightline+vnodes-nest@gmail.com",
    "name": "Robert Brightline",
    "url": "https://vnodes.github.io"
  },
  "keywords": [
    "library",
    "types"
  ],
  "bugs": {
    "email": "robert.brightline+vnodes-nest@gmail.com",
    "url": "https://github.com/vnodes/vnodes/issues"
  },
  "homepage": "https://vnodes.github.io/packages/nest",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "files": [
    "dist",
    "assets",
    "!**/*.tsbuildinfo"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@vnodes/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "sourceRoot": "packages/nest/src",
    "tags": [
      "lib:shared"
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "{projectRoot}/dist",
          "main": "{projectRoot}/src/index.ts",
          "tsConfig": "{projectRoot}/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  },
  "devDependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@vnodes/types": "workspace:*",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@vnodes/types": "workspace:*",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "rxjs": "^7.8.2"
  }
}