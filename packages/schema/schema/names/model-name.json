{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ModelName",
  "description": "Model name enum",
  "anyOf": [{ "$ref": "#/definitions/Common" }, { "$ref": "#/definitions/Auth" }],

  "definitions": {
    "Common": {
      "title": "CommonModelName",
      "enum": ["Id", "Audit", "Category"]
    },
    "Auth": {
      "title": "AuthModelName",

      "enum": ["User", "Role", "Permission"]
    }
  }
}
