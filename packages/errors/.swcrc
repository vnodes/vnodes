{
  "jsc": {
    "target": "es2022",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "keepClassNames": true,
    "externalHelpers": true,
    "loose": false
  },
  "module": {
    "type": "nodenext",
    "strict": true,
    "strictMode": true
  },
  "sourceMaps": true,
  "exclude": [
    "node_modules",
    ".*\\.spec\\.ts$",
    "vitest\\.config\\.[cm]?ts$",
    "eslint\\.config\\.[cm]?js$"
  ]
}
