{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "StringProperty",
    "$id": "StringProperty",
    "properties": {
        "type": {
            "const": "string"
        },
        "minLength": {
            "type": "number"
        },
        "maxLength": {
            "type": "number"
        },
        "isIn": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "isNotIn": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "format": {
            "$ref": "./../enums/string-format.json"
        }
    },
    "required": [
        "type"
    ]
}